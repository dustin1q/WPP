---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="UI/UX Architectural Principles">
    <style>
        .principles-list {
            margin-top: 2rem;
            margin-bottom: 2rem;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .ui-details {
            border: 1px solid rgba(255, 255, 255, 0.07);
            border-radius: 0.375rem;
            overflow: hidden;
            width: 100%;
            box-sizing: border-box;
            background: var(--color-dark-grey, #323232);
        }

        .ui-summary {
            padding: 0.85rem 1rem;
            font-family: "Space Grotesk1", Arial, sans-serif;
            font-weight: 500;
            font-size: 0.95rem;
            letter-spacing: 0.5px;
            color: var(--color-light-grey, #c0bcbc);
            cursor: pointer;
            user-select: none;
            background-color: transparent;
            transition: all 0.2s ease-in-out;
            list-style: none;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            width: 100%;
            box-sizing: border-box;
        }

        .ui-summary::-webkit-details-marker {
            display: none;
        }

        .ui-summary:hover {
            color: var(--color-primary, #eeeded);
            background: rgba(255, 255, 255, 0.05);
        }

        .ui-summary::before {
            content: "▶";
            display: inline-block;
            transition: transform 0.2s ease-in-out;
            font-size: 0.65rem;
            color: rgba(255, 255, 255, 0.35);
            flex-shrink: 0;
        }

        .ui-details[open] .ui-summary {
            color: var(--color-accent, rgb(245 158 11));
        }

        .ui-details[open] .ui-summary::before {
            transform: rotate(90deg);
            color: var(--color-accent, rgb(245 158 11));
        }

        .ui-details-content {
            padding: 1rem 1.25rem;
            border-top: 1px solid rgba(255, 255, 255, 0.07);
            background-color: rgba(0, 0, 0, 0.25);
            animation: slideDown 0.2s ease-in-out;
            width: 100%;
            box-sizing: border-box;
            overflow-wrap: break-word;
            color: var(--color-light-grey, #c0bcbc);
            font-size: 0.9rem;
            line-height: 1.6;
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-0.5rem);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
    <section class="breakout">
        <article>
            <section>
                <section class="principles-list">
                    <details class="ui-details" name="accordionGroup">
                        <summary class="ui-summary"
                            >Reduce Critical path loading and unnecessary script
                            blocking.</summary
                        >
                        <div class="ui-details-content">
                            <p>Leverage async and defer load where possible</p>
                        </div>
                    </details>

                    <details class="ui-details" name="accordionGroup">
                        <summary class="ui-summary"
                            >Tree-shake bundles and eliminate loading of dead or
                            unused code</summary
                        >
                        <div class="ui-details-content">
                            <p>
                                Improves page load and overall UI performance.
                                Improve Caching &amp; reduce bandwidth usage
                            </p>
                        </div>
                    </details>

                    <details class="ui-details" name="accordionGroup">
                        <summary class="ui-summary"
                            >Defined performance budgets &amp; adhere to them</summary
                        >
                        <div class="ui-details-content">
                            <p>
                                Set Performance goals. Setup ongoing measurement
                                &amp; monitoring tools for reporting. Establish
                                escalation processes for performance guardrails
                                &amp; remediation.
                            </p>
                        </div>
                    </details>

                    <details class="ui-details" name="accordionGroup">
                        <summary class="ui-summary"
                            >Follow web API, platform best practices &amp;
                            leverage native web APIs when possible</summary
                        >
                        <div class="ui-details-content">
                            <p>
                                Monitor emerging capabilities &amp; UI best
                                practices through MDN and W3C. Stay UpToDate
                                with cross-browser support on emerging specs and
                                XE support. (caniuse.com)
                            </p>
                        </div>
                    </details>

                    <details class="ui-details" name="accordionGroup">
                        <summary class="ui-summary"
                            >Reduce complexity, Adopt frameworks responsibly</summary
                        >
                        <div class="ui-details-content">
                            <p>
                                Framework adoption should always be weighted
                                against the complexities &amp; requirements. Use
                                frameworks only when solving complex UI/UX
                                problems. Do not adopt frameworks without a
                                business need. Always Leverage native browser
                                capabilities over framework adoption. This will
                                reduce complexity &amp; leads to performant UI
                                with a maintainable code base.
                            </p>
                        </div>
                    </details>

                    <details class="ui-details" name="accordionGroup">
                        <summary class="ui-summary"
                            >Follow Web Content Accessibility Guidelines (WCAG)
                            2.0</summary
                        >
                        <div class="ui-details-content">
                            <p>
                                <a href="https://www.w3.org/TR/WCAG20/"
                                    >https://www.w3.org/TR/WCAG20/</a
                                ><br />
                                Test UI with Screen Readers on Mac (Voice Over) and
                                PC (NVDA).<br />
                                Test UI Designs against for contrast ratio guidelines
                                <a href="https://webaim.org/articles/contrast/"
                                    >https://webaim.org/articles/contrast/</a
                                >
                            </p>
                        </div>
                    </details>
                </section>
            </section>
        </article>
    </section>
</MainLayout>
