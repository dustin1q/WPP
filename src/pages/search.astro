---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Search Results" noSearch="true">
    <section class="breakout">
        <aside>
            <form class="search">
                <label for="search"></label>
                <input
                    type="search"
                    required
                    min="2"
                    max="24"
                    name="search"
                    id="search"
                    placeholder="Enter a search term..."
                />
            </form>
        </aside>
        <p id="searchReadout"></p>
        <h3 id="searchNumber"></h3>
        <section aria-label="Search Results">
            <ul id="resultsList"></ul>
        </section>
        <script src="../js/search.js"></script>
    </section>
</MainLayout>

<style>
    #resultsList {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.5em;
        padding: 0;

        li {
            display: flex;
            flex-direction: column;
            padding: 1rem;
            background: var(--color-dark-grey, #323232);
            border: 1px solid rgba(255, 255, 255, 0.07);
            border-radius: 0.375rem;
        }

        a {
            color: var(--color-accent, rgb(245 158 11));
            text-decoration: underline;
            font-weight: 500;
            align-self: flex-start;
            font-family: "Space Grotesk1", Arial, sans-serif;
            font-size: 1.1rem;
            margin-top: 0.5rem;
        }

        p {
            padding: 0px;
            font-size: 0.9rem;
            display: block;
            color: var(--color-light-grey, #c0bcbc);
        }

        textarea {
            background: transparent;
            color: var(--color-light-grey, #c0bcbc);
            font-family: inherit;
            font-size: 0.9rem;
            line-height: 1.5;
            border: none;
            resize: none;
            overflow: hidden;
            padding: 0;
            margin: 0;
            width: 100%;
        }
    }

    .search {
        display: grid;
        gap: 0.6rem;
        max-width: 32ch;
        margin-bottom: 2rem;
        margin-inline: auto;

        input {
            font: inherit;
            font-size: 12px;
            border-radius: 3px;
            height: 25px;
            padding: 5px;
            background: var(--color-dark-grey, #323232);
            border: 1px solid rgba(255, 255, 255, 0.15);
            color: var(--color-light-grey, #c0bcbc);
            transition: border-color 0.2s ease-in-out;
            width: 100%;
        }

        input:focus {
            outline: none;
            border-color: var(--color-accent, rgb(245 158 11));
        }

        ::placeholder {
            color: rgba(255, 255, 255, 0.4);
            opacity: 1;
            font-size: 12px;
        }
    }
</style>
